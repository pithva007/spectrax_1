# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials
# Get these from Firebase Console: https://console.firebase.google.com/

# Firebase Project Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase App Check (anti-abuse protection for Authentication)
# reCAPTCHA Enterprise site key. Leave empty to disable App Check (local dev / demo).
# Requires enabling App Check with the reCAPTCHA Enterprise provider in the Firebase
# console and turning on enforcement for Authentication. See issue #293 for setup steps.
VITE_APPCHECK_RECAPTCHA_KEY=

# Backend CORS Configuration
# Set this to your deployed frontend URL in production (e.g. https://yourapp.com)
# Defaults to http://localhost:5173 for local development if not set
ALLOWED_ORIGIN=http://localhost:5173